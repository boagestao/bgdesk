[Unit]
Description=BGDesk
Requires=network.target
After=systemd-user-sessions.service

[Service]
Type=simple
ExecStart=/usr/bin/bgdesk --service
# kill --tray and --server both
ExecStop=pkill -f "bgdesk --"
# below two lines do not work, have to use above one line
#ExecStop=pkill -f "bgdesk --tray"
#ExecStop=pkill -f "bgdesk --server"
PIDFile=/run/bgdesk.pid
KillMode=mixed
TimeoutStopSec=30
User=root
LimitNOFILE=100000

[Install]
WantedBy=multi-user.target
